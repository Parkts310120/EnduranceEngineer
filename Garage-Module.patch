new file mode 100644
index 0000000..163c639
--- /dev/null
+++ b/frontend/src/features/workspace/services/garageService.js
@@ -0,0 +1,141 @@
+const garageCars = [
+  {
+    id: 'car-27',
+    name: 'Falcon GT3',
+    model: 'BMW M4 GT3 Evo',
+    number: '#27',
+    category: 'GT3 Pro',
+    status: 'Ready',
+    fuel: 86,
+    tyreLife: 78,
+    lastDriver: 'Marina Costa',
+    setup: 'Barcelona Race v4',
+    nextMaintenance: 'Brake inspection after FP2',
+  },
+  {
+    id: 'car-88',
+    name: 'Night Hawk',
+    model: 'Porsche 911 GT3 R',
+    number: '#88',
+    category: 'GT3 Am',
+    status: 'Garage',
+    fuel: 64,
+    tyreLife: 51,
+    lastDriver: 'Rafael Lima',
+    setup: 'Safe wet baseline',
+    nextMaintenance: 'Refuel and tyre pressure reset',
+  },
+  {
+    id: 'car-12',
+    name: 'Apex Prototype',
+    model: 'Ligier JS P320',
+    number: '#12',
+    category: 'LMP3',
+    status: 'On Track',
+    fuel: 38,
+    tyreLife: 42,
+    lastDriver: 'Nico Alvarez',
+    setup: 'High downforce race trim',
+    nextMaintenance: 'Fuel stop in 18 minutes',
+  },
+  {
+    id: 'car-44',
+    name: 'Reserve GT4',
+    model: 'Mercedes-AMG GT4',
+    number: '#44',
+    category: 'GT4',
+    status: 'Maintenance',
+    fuel: 22,
+    tyreLife: 18,
+    lastDriver: 'João Mendes',
+    setup: 'Qualifying baseline',
+    nextMaintenance: 'Replace front-left tyre sensor',
+  },
+]
+
+const statusTone = {
+  Ready: 'success',
+  Garage: 'neutral',
+  'On Track': 'accent',
+  Maintenance: 'warning',
+}
+
+const statusPriority = {
+  Maintenance: 0,
+  'On Track': 1,
+  Garage: 2,
+  Ready: 3,
+}
+
+function getFuelTone(fuel) {
+  if (fuel < 30) return 'danger'
+  if (fuel < 55) return 'warning'
+  return 'success'
+}
+
+function getTyreTone(tyreLife) {
+  if (tyreLife < 25) return 'danger'
+  if (tyreLife < 55) return 'warning'
+  return 'success'
+}
+
+function getMaintenanceAlerts(cars) {
+  return cars
+    .filter((car) => car.status === 'Maintenance' || car.fuel < 30 || car.tyreLife < 25)
+    .map((car) => ({
+      id: `${car.id}-alert`,
+      car: `${car.number} ${car.name}`,
+      title: car.status === 'Maintenance' ? 'Maintenance required' : 'Consumable threshold reached',
+      description:
+        car.status === 'Maintenance'
+          ? car.nextMaintenance
+          : `Fuel at ${car.fuel}% and tyre life at ${car.tyreLife}%. Prepare service plan.`,
+      tone: car.status === 'Maintenance' || car.tyreLife < 25 ? 'warning' : 'danger',
+    }))
+}
+
+function getGarageStats(cars) {
+  return {
+    total: cars.length,
+    ready: cars.filter((car) => car.status === 'Ready').length,
+    onTrack: cars.filter((car) => car.status === 'On Track').length,
+    maintenance: cars.filter((car) => car.status === 'Maintenance').length,
+  }
+}
+
+export function getGarage() {
+  const cars = garageCars
+    .map((car) => ({
+      ...car,
+      statusTone: statusTone[car.status] ?? 'neutral',
+      fuelTone: getFuelTone(car.fuel),
+      tyreTone: getTyreTone(car.tyreLife),
+    }))
+    .sort((a, b) => statusPriority[a.status] - statusPriority[b.status])
+
+  const stats = getGarageStats(cars)
+
+  return {
+    hero: {
+      title: 'Garage Module',
+      description: 'Monitor the team cars, readiness, consumables and maintenance queue from one workspace module.',
+      status: `${stats.ready}/${stats.total} cars ready`,
+    },
+    stats,
+    cars,
+    statusPanel: [
+      { label: 'Ready', value: stats.ready, tone: 'success' },
+      { label: 'Garage', value: cars.filter((car) => car.status === 'Garage').length, tone: 'neutral' },
+      { label: 'On Track', value: stats.onTrack, tone: 'accent' },
+      { label: 'Maintenance', value: stats.maintenance, tone: 'warning' },
+    ],
+    nextMaintenances: cars.map((car) => ({
+      id: `${car.id}-maintenance`,
+      car: `${car.number} ${car.name}`,
+      task: car.nextMaintenance,
+      status: car.status,
+      tone: car.statusTone,
+    })),
+    alerts: getMaintenanceAlerts(cars),
+  }
+}
-- 
