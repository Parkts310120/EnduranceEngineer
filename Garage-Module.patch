+  return (
+    <Card className="garage-car-card">
+      <div className="garage-car-card__header">
+        <div>
+          <span className="eyebrow">{car.category}</span>
+          <h3>{car.number} {car.name}</h3>
+        </div>
+        <Badge tone={car.statusTone}>{car.status}</Badge>
+      </div>
