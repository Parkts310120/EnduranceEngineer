+import Badge from '../../../shared/ui/Badge'
+import Card from '../../../shared/ui/Card'
+
+export default function GarageSummaryCards({ stats }) {
+  const cards = [
+    { label: 'Total cars', value: stats.total, tone: 'accent' },
+    { label: 'Ready', value: stats.ready, tone: 'success' },
+    { label: 'On track', value: stats.onTrack, tone: 'accent' },
+    { label: 'Maintenance', value: stats.maintenance, tone: 'warning' },
+  ]
+
+  return (
+    <section className="garage-summary-grid" aria-label="Garage summary">
+      {cards.map((card) => (
+        <Card className="garage-summary-card" key={card.label}>
+          <span className="eyebrow">{card.label}</span>
+          <strong>{card.value}</strong>
+          <Badge tone={card.tone}>{card.label}</Badge>
+        </Card>
+      ))}
+    </section>
+  )
+}
