+import GarageAlerts from '../components/GarageAlerts'
+import GarageCarCard from '../components/GarageCarCard'
+import GarageHero from '../components/GarageHero'
+import GarageMaintenanceList from '../components/GarageMaintenanceList'
+import GarageStatusPanel from '../components/GarageStatusPanel'
+import GarageSummaryCards from '../components/GarageSummaryCards'
+import { getGarage } from '../services/garageService'
+
+export default function CarsScreen() {
+  const garage = getGarage()
+
+  return (
+    <section className="screen-stack garage-screen">
+      <GarageHero hero={garage.hero} />
+      <GarageSummaryCards stats={garage.stats} />
+
+      <section className="garage-layout">
+        <section className="garage-car-grid" aria-label="Garage cars">
+          {garage.cars.map((car) => (
+            <GarageCarCard car={car} key={car.id} />
+          ))}
+        </section>
+
+        <aside className="garage-side-panel">
+          <GarageStatusPanel statuses={garage.statusPanel} />
+          <GarageMaintenanceList maintenances={garage.nextMaintenances} />
+          <GarageAlerts alerts={garage.alerts} />
+        </aside>
+      </section>
+    </section>
+  )
+}
