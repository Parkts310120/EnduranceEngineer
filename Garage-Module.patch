+import Badge from '../../../shared/ui/Badge'
+import Card from '../../../shared/ui/Card'
+
+export default function GarageAlerts({ alerts }) {
+  return (
+    <Card className="garage-alerts">
+      <span className="eyebrow">Maintenance alerts</span>
+      <h2>Attention needed</h2>
+      <div className="garage-alert-list">
+        {alerts.length === 0 ? (
+          <p>No active maintenance alerts. Keep monitoring fuel, tyre life and setup readiness.</p>
+        ) : (
+          alerts.map((alert) => (
+            <article className="garage-alert" key={alert.id}>
+              <div>
+                <strong>{alert.title}</strong>
+                <span>{alert.car}</span>
+                <p>{alert.description}</p>
+              </div>
+              <Badge tone={alert.tone}>Alert</Badge>
+            </article>
+          ))
+        )}
+      </div>
+    </Card>
+  )
+}
