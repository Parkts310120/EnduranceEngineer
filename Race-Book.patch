diff --git a/frontend/src/app/styles.css b/frontend/src/app/styles.css
index b5984fa..2fc1bd2 100644
--- a/frontend/src/app/styles.css
+++ b/frontend/src/app/styles.css
@@ -575,3 +575,137 @@ a {
     grid-template-columns: 1fr;
   }
 }
+
+.ui-button--secondary {
+  background: #242a3a;
+  border: 1px solid #343b50;
+  color: var(--text);
+}
+
+.race-book-screen {
+  max-width: 1440px;
+}
+
+.race-book-hero {
+  position: relative;
+  overflow: hidden;
+}
+
+.race-book-hero::after {
+  content: '';
+  position: absolute;
+  inset: auto -80px -120px auto;
+  width: 260px;
+  height: 260px;
+  background: rgba(124, 92, 255, 0.16);
+  border-radius: 999px;
+  filter: blur(8px);
+}
+
+.race-book-hero > * {
+  position: relative;
+  z-index: 1;
+}
+
+.race-book-stats,
+.race-book-card__header,
+.race-book-card__meta,
+.race-book-important__item {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+}
+
+.race-book-stats {
+  flex-wrap: wrap;
+  justify-content: flex-end;
+  min-width: min(340px, 100%);
+}
+
+.race-book-layout {
+  display: grid;
+  grid-template-columns: 1.4fr 0.8fr;
+  gap: 18px;
+}
+
+.race-book-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 18px;
+}
+
+.race-book-card {
+  display: flex;
+  flex-direction: column;
+  gap: 18px;
+  min-height: 320px;
+}
+
+.race-book-card h3,
+.race-book-important h2,
+.race-book-missing-summary h2 {
+  margin: 8px 0 0;
+}
+
+.race-book-card__meta {
+  border-top: 1px solid var(--border);
+  color: var(--muted);
+  font-size: 13px;
+  margin-top: auto;
+  padding-top: 16px;
+}
+
+.race-book-empty-state {
+  background: rgba(255, 198, 88, 0.1);
+  border: 1px dashed rgba(255, 198, 88, 0.45);
+  border-radius: 14px;
+  color: #ffd98a;
+  display: grid;
+  gap: 6px;
+  padding: 14px;
+}
+
+.race-book-empty-state span,
+.race-book-important__item span {
+  color: var(--muted);
+  font-size: 13px;
+}
+
+.race-book-card--missing {
+  border-color: rgba(255, 198, 88, 0.35);
+}
+
+.race-book-important__list {
+  display: grid;
+  gap: 12px;
+  margin-top: 18px;
+}
+
+.race-book-important__item {
+  background: #11151f;
+  border: 1px solid #252a3a;
+  border-radius: 14px;
+  padding: 12px;
+}
+
+@media (max-width: 1180px) {
+  .race-book-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 860px) {
+  .race-book-layout,
+  .race-book-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .race-book-stats,
+  .race-book-card__header,
+  .race-book-card__meta,
+  .race-book-important__item {
+    align-items: stretch;
+    flex-direction: column;
+  }
+}
diff --git a/frontend/src/features/workspace/components/RaceBookDocumentCard.jsx b/frontend/src/features/workspace/components/RaceBookDocumentCard.jsx
new file mode 100644
index 0000000..74a9c0a
--- /dev/null
+++ b/frontend/src/features/workspace/components/RaceBookDocumentCard.jsx
@@ -0,0 +1,33 @@
+import Badge from '../../../shared/ui/Badge'
+import Button from '../../../shared/ui/Button'
+import Card from '../../../shared/ui/Card'
+
+export default function RaceBookDocumentCard({ document }) {
+  return (
+    <Card className={`race-book-card ${document.isMissing ? 'race-book-card--missing' : ''}`}>
+      <div className="race-book-card__header">
+        <div>
+          <span className="eyebrow">{document.category}</span>
+          <h3>{document.title}</h3>
+        </div>
+        <Badge tone={document.statusTone}>{document.statusLabel}</Badge>
+      </div>
+
+      <p>{document.description}</p>
+
+      {document.isMissing ? (
+        <div className="race-book-empty-state">
+          <strong>Document not created yet</strong>
+          <span>Create this page before race mode so the team has a single source of truth.</span>
+        </div>
+      ) : null}
+
+      <div className="race-book-card__meta">
+        <span>Owner: {document.owner}</span>
+        <span>Updated: {document.updatedAt}</span>
+      </div>
+
+      <Button variant={document.isMissing ? 'primary' : 'secondary'}>{document.primaryAction}</Button>
+    </Card>
+  )
+}
diff --git a/frontend/src/features/workspace/components/RaceBookImportantDocuments.jsx b/frontend/src/features/workspace/components/RaceBookImportantDocuments.jsx
new file mode 100644
index 0000000..25e7194
--- /dev/null
+++ b/frontend/src/features/workspace/components/RaceBookImportantDocuments.jsx
@@ -0,0 +1,28 @@
+import Badge from '../../../shared/ui/Badge'
+import Card from '../../../shared/ui/Card'
+
+export default function RaceBookImportantDocuments({ documents }) {
+  return (
+    <Card className="race-book-important">
+      <div className="mission-card-heading">
+        <div>
+          <span className="eyebrow">Important documents</span>
+          <h2>Must-read before race mode</h2>
+        </div>
+        <Badge tone="accent">{documents.length} pinned</Badge>
+      </div>
+
+      <div className="race-book-important__list">
+        {documents.map((document) => (
+          <div className="race-book-important__item" key={document.id}>
+            <div>
+              <strong>{document.title}</strong>
+              <span>{document.owner}</span>
+            </div>
+            <Badge tone={document.statusTone}>{document.statusLabel}</Badge>
+          </div>
+        ))}
+      </div>
+    </Card>
+  )
+}
